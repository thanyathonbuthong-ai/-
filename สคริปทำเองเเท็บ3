    local orbiting = false

    orbit_tool.Equipped:Connect(function()
        local mouse = Player:GetMouse()
        orbiting = true

        mouse_connection = mouse.Button1Down:Connect(function()
            local part = mouse.Target
            if not part or not part:IsA("BasePart") then return end
            
            if part.Anchored then 
                warn("Part is anchored, cannot orbit.")
                return
            end
            
            local hrp = Player.Character:WaitForChild("HumanoidRootPart")
            part.CanCollide = false
            part.CanTouch = false
            part.CanQuery = false
            part.Massless = true

            local radius = 5
            local angle = 0
            local height = 0.5
            local speed = 0.05

            task.spawn(function()
                while orbiting and hrp and hrp.Parent do
                    angle += speed
                    local offset = Vector3.new(math.cos(angle) * radius, height, math.sin(angle) * radius)
                    part.CFrame = CFrame.new(hrp.Position + offset, hrp.Position)
                    task.wait()
                end
            end)
        end)
    end)

    orbit_tool.Unequipped:Connect(function()
        if mouse_connection then mouse_connection:Disconnect() end
        orbiting = false
    end)
