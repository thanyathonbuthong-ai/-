        SeatModeBtn.Text = "🪑 Seat Mode: ON"
        SeatModeBtn.BackgroundColor3 = Accent
        SeatModeBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
        
        local character = Player.Character
        if not character then
            seatModeActive = false
            SeatModeBtn.Text = "🪑 Seat Mode: OFF"
            SeatModeBtn.BackgroundColor3 = Secondary
            SeatModeBtn.TextColor3 = White
            return
        end
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local savedPos = hrp.CFrame
        
        character:MoveTo(Vector3.new(0, 1e6, 0))
        task.wait(1)
        
        currentSeat = Instance.new("Seat")
        currentSeat.Anchored = false
        currentSeat.CanCollide = false
        currentSeat.Transparency = 1
        currentSeat.CFrame = CFrame.new(0, 1e6, 0)
        currentSeat.Parent = workspace
        
        local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        if torso then
            currentWeld = Instance.new("Weld")
            currentWeld.Part0 = currentSeat
            currentWeld.Part1 = torso
            currentWeld.Parent = currentSeat
        end
        
        currentSeat.CFrame = savedPos
        
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Transparency = 0.7
            end
        end
    else
        SeatModeBtn.Text = "🪑 Seat Mode: OFF"
        SeatModeBtn.BackgroundColor3 = Secondary
        SeatModeBtn.TextColor3 = White
        
        if currentSeat then
            currentSeat:Destroy()
            currentSeat = nil
        end
        currentWeld = nil
        
        local character = Player.Character
        if character then
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Transparency = 0
                end
            end
        end
    end
end)

