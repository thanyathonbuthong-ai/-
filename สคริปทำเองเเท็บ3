local function toggleClicker()
    clicking = not clicking
    StartBtn.Text = clicking and "STOP" or "START"
    StartBtn.BackgroundColor3 = clicking and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(80, 0, 180)
end

local function updateCPS()
    local val = tonumber(CPSInput.Text)
    if val then
        if not unstoppable then
            val = math.clamp(val, 1, maxCPS)
            CPSInput.Text = tostring(val)
        end
        cps = val
        Tooltip.Visible = (val >= 500)
    end
end

CPSInput.FocusLost:Connect(updateCPS)
StartBtn.MouseButton1Click:Connect(toggleClicker)

