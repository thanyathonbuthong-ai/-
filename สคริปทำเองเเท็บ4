        p.Lifetime = NumberRange.new(0.5)
        p.Speed = NumberRange.new(3)
        p.Size = NumberSequence.new{NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1.5)}
        p.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(0.1,0),NumberSequenceKeypoint.new(0.55,0.75),NumberSequenceKeypoint.new(1,1)}
        p.Acceleration = Vector3.new(0,-30,0)
        p.Orientation = Enum.ParticleOrientation.FacingCamera
        p.Parent = splashes
    end
    local rainSound = Instance.new("Sound")
    rainSound.SoundId = "rbxassetid://3786250088"
    rainSound.Looped = true
    rainSound.Volume = 1
    rainSound.RollOffMaxDistance = 10000
    rainSound.RollOffMinDistance = 10
    rainSound.Parent = rainModel
    rainSound:Play()
    local MAX_LIGHTS = 150
    giLights = {}
    local function isCharacterPart(part)
        local model = part:FindFirstAncestorOfClass("Model")
        return model and Players:GetPlayerFromCharacter(model)
    end
    local function createBounce(part)
        if not part:IsA("BasePart") then return end
        if isCharacterPart(part) then return end
        if part.Transparency > 0.6 then return end
        if part.Size.Magnitude < 3 then return end
        if #giLights >= MAX_LIGHTS then return end
        if part:FindFirstChild("GI_Bounce") then return end
        local att = Instance.new("Attachment")
        att.Name = "GI_Bounce"
        att.Position = Vector3.new(0, part.Size.Y/2, 0)
        att.Parent = part
        local light = Instance.new("PointLight")
        light.Name = "GI_Light"
        light.Range = math.clamp(part.Size.Magnitude*3,25,60)
        light.Brightness = 1.35
        light.Color = part.Color
        light.Shadows = false
        light.Parent = att
        giLights[#giLights+1] = light
    end
    local function applyBounce()
        for _,v in ipairs(Workspace:GetDescendants()) do createBounce(v) end
    end
    applyBounce()
    table.insert(giConnections, Workspace.DescendantAdded:Connect(createBounce))
    table.insert(giConnections, RunService.Heartbeat:Connect(function()
        for i=1,#giLights do
            local light = giLights[i]
            local part = light.Parent and light.Parent.Parent
            if part and part:IsA("BasePart") and not isCharacterPart(part) then
                light.Color = part.Color
                light.Range = math.clamp(part.Size.Magnitude*3,25,60)
            end
        end
    end))
    table.insert(giConnections, spawn(function()
        while isGiEnabled do
            Terrain.WaterWaveSpeed = 25 + math.sin(tick()*0.5)*15
            Terrain.WaterWaveSize = 0.45 + math.sin(tick()*0.3)*0.2
            task.wait(0.1)
        end
    end))
    table.insert(giConnections, RunService.RenderStepped:Connect(function()
        if camera and rainModel then
            local cf = camera.CFrame
            drops.CFrame = cf + cf.LookVector*10 + Vector3.new(0,5,0)
            splashes.CFrame = cf + cf.LookVector*10 - Vector3.new(0,10,0)
        end
    end))
    table.insert(giConnections, player.CharacterAdded:Connect(function()
        task.wait(0.5)
        applyBounce()
    end))
end

local function disableGI()
    isGiEnabled = false
    if rainModel then rainModel:Destroy() rainModel = nil end
    for _, light in ipairs(giLights) do
        if light and light.Parent then light.Parent:Destroy() end
    end
    giLights = {}
    for _, conn in ipairs(giConnections) do
        if conn then pcall(function() conn:Disconnect() end) end
    end
    giConnections = {}
    for _,v in pairs(Lighting:GetChildren()) do
        if v:IsA("Sky") or v:IsA("SunRaysEffect") or v:IsA("Atmosphere") or v:IsA("DepthOfFieldEffect") or v:IsA("Clouds") then
            v:Destroy()
        end
    end
end

GiBtn.MouseButton1Down:Connect(function()
    isGiEnabled = not isGiEnabled
    if isGiEnabled then
        GiBtn.Text = "REALISTIC GI & RAIN: ON"
        GiBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 150)
        enableGI()
    else
        GiBtn.Text = "REALISTIC GI & RAIN: OFF"
        GiBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 40)
        disableGI()
    end
end)

