-- ==================== Freecam Logic ====================
local freecam = false
local speed = 2
local smoothness = 0.15
local velocity = Vector3.zero
local rotation = Vector2.zero
local currentRotation = Vector2.zero
local touchDragging = false
local lastTouchPos = nil
local pressed = { X = 0, Z = 0 }
local lockConnection
local originalWalkSpeed
local originalJumpPower
local savedCFrame
local currentCharacter

pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.TouchControls, true) end)

local function bind(btn, axis, value)
    btn.InputBegan:Connect(function(input)
        if not freecam then return end
        if input.UserInputType == Enum.UserInputType.Touch then
            if axis == "X" then pressed.X += value else pressed.Z += value end
        end
    end)
    btn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            if axis == "X" then pressed.X -= value else pressed.Z -= value end
        end
    end)
end

bind(Forward,"Z",-1)
bind(Backward,"Z",1)
bind(Left,"X",-1)
bind(Right,"X",1)

local function startLock(char)
    currentCharacter = char
    local hrp = char:WaitForChild("HumanoidRootPart")
    local humanoid = char:WaitForChild("Humanoid")
    originalWalkSpeed = humanoid.WalkSpeed
    originalJumpPower = humanoid.JumpPower
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    savedCFrame = hrp.CFrame
    if lockConnection then lockConnection:Disconnect() end
    lockConnection = RunService.Heartbeat:Connect(function()
        if freecam and hrp.Parent then
            hrp.CFrame = savedCFrame
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end
    end)
end

local function stopLock()
    if not currentCharacter then return end
    local char = currentCharacter
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if lockConnection then lockConnection:Disconnect() lockConnection = nil end
    if humanoid then
        humanoid.WalkSpeed = originalWalkSpeed or 16
        humanoid.JumpPower = originalJumpPower or 50
    end
    if hrp then
        hrp.AssemblyLinearVelocity = Vector3.zero
        hrp.AssemblyAngularVelocity = Vector3.zero
    end
    savedCFrame = nil
end

local function enableFreecam()
    freecam = true
    velocity = Vector3.zero
    rotation = Vector2.zero
    currentRotation = Vector2.zero
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.TouchControls, false) end)
    local char = player.Character
    if char and char:FindFirstChild("Head") then
        camera.CFrame = char.Head.CFrame
        startLock(char)
    end
    camera.CameraType = Enum.CameraType.Scriptable
    ControlGui.Enabled = true
end

local function disableFreecam()
    freecam = false
    pressed.X = 0
    pressed.Z = 0
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.TouchControls, true) end)
    stopLock()
    camera.CameraType = Enum.CameraType.Custom
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        camera.CameraSubject = player.Character.Humanoid
    end
    ControlGui.Enabled = false
end

FreecamBtn.MouseButton1Down:Connect(function()
    if freecam then
        disableFreecam()
        FreecamBtn.Text = "FREECAM: OFF"
        FreecamBtn.BackgroundColor3 = Color3.fromRGB(0, 40, 40)
    else
        enableFreecam()
        FreecamBtn.Text = "FREECAM: INSTANT"
        FreecamBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 120)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not freecam then return end
    if input.UserInputType == Enum.UserInputType.Touch then
        if not touchDragging then
            touchDragging = true
            lastTouchPos = input.Position
        else
            local delta = input.Position - lastTouchPos
            lastTouchPos = input.Position
            rotation += Vector2.new(-delta.Y, -delta.X) * 0.2
        end
    end
end)

UserInputService.TouchEnded:Connect(function()
    touchDragging = false
    lastTouchPos = nil
end)

RunService.RenderStepped:Connect(function()
    if not freecam then return end
    currentRotation = currentRotation:Lerp(rotation, smoothness)
    local camCF = CFrame.new(camera.CFrame.Position) * CFrame.Angles(0, math.rad(currentRotation.Y), 0) * CFrame.Angles(math.rad(currentRotation.X), 0, 0)
    local moveVector = Vector3.new(pressed.X,0,pressed.Z)
    if moveVector.Magnitude > 1 then moveVector = moveVector.Unit end
    velocity = velocity:Lerp(camCF:VectorToWorldSpace(moveVector) * speed, smoothness)
    camera.CFrame = camCF + velocity
end)

player.CharacterAdded:Connect(function(char)
    task.wait(0.1)
    if freecam then startLock(char) end
end)

