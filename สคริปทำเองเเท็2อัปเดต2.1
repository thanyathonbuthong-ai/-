-- === ฟังก์ชัน Setup ระบบ Zero Gravity ===
local function setupZeroG(character)
    local root = character:WaitForChild("HumanoidRootPart")
    local hum = character:WaitForChild("Humanoid")
    hum.PlatformStand = false

    zeroGAttach = root:FindFirstChild("RootAttachment") or Instance.new("Attachment", root)
    if zeroGForce then zeroGForce:Destroy() end

    zeroGForce = Instance.new("VectorForce")
    zeroGForce.Attachment0 = zeroGAttach
    zeroGForce.RelativeTo = Enum.ActuatorRelativeTo.World
    zeroGForce.Parent = root
end

-- เรียกใช้ครั้งแรก
if player.Character then setupZeroG(player.Character) end

