local function createTab(text, posX)
    local tab = Instance.new("TextButton")
    tab.Size = UDim2.new(0.135, 0, 1, 0)
    tab.Position = UDim2.new(posX, 0, 0, 0)
    tab.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    tab.TextColor3 = Color3.fromRGB(150, 150, 150)
    tab.Text = text; tab.TextSize = 8; tab.Font = Enum.Font.GothamBold
    tab.Parent = tabFrame
    Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 6)
    return tab
end

